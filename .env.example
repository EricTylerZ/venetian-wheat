# Venetian Wheat — Environment Variables
# Copy this to .env and fill in your keys

# Venice AI API (optional — for Venice LLM provider)
VENICE_API_KEY=

# Grok / xAI API (optional — for automated daily channel scans)
XAI_API_KEY=

# Note: Claude Code uses its own auth via `claude` CLI
# Run `claude` in terminal to authenticate
