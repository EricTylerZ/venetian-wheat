# GitHub personal access token (fine-grained, repo scope)
# Create at: https://github.com/settings/tokens?type=beta
# Permissions needed: Contents (read/write), Metadata (read)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Your GitHub username or org
GITHUB_OWNER=EricTylerZ

# The repo to monitor (venetian-wheat)
GITHUB_REPO=venetian-wheat

# Optional: shared secret to protect the dashboard
# Set this in Vercel environment variables
DASHBOARD_SECRET=
