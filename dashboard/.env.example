# GitHub personal access token (fine-grained, repo scope)
# Create at: https://github.com/settings/tokens?type=beta
# Permissions needed: Contents (read/write), Metadata (read)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Your GitHub username or org
GITHUB_OWNER=EricTylerZ

# The repo to monitor (venetian-wheat)
GITHUB_REPO=venetian-wheat

# Password to protect the dashboard (REQUIRED for production)
# Set this in Vercel environment variables
# Users enter this once, get a 30-day cookie
DASHBOARD_PASSWORD=your-secret-password-here

# --- Namecheap Server (optional, enables Server Monitor tab) ---
# Base URL of your wheat-api folder on Namecheap, no trailing slash
# Example: https://ericzosso.com/wheat-api
WHEAT_SERVER_URL=https://ericzosso.com/wheat-api

# Random API key — must match WHEAT_API_KEY in server/config.php
# Generate: openssl rand -hex 32  (or any 32+ char random string)
WHEAT_API_KEY=your-random-api-key-here
